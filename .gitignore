# Composer + test harness build artifacts.
# Everything under .Build/ is generated by `composer install` and the
# typo3/testing-framework (vendor/, bin/, the .Build/public web root used for
# functional tests, and the .Build/.cache PHPUnit cache). Never commit it.
/.Build/

# Extensions do not ship a lock file; the integrating project pins versions.
/composer.lock

# PHPUnit / PHPStan caches, in case a run writes them to the package root
# instead of into .Build/.cache.
/.phpunit.cache/
/.phpunit.result.cache
/.phpstan/

# Local secrets / credentials — must never be committed.
# (DeepL keys, Composer auth tokens, local env overrides.)
/auth.json
/.env
/.env.*

# OS / editor noise
.DS_Store
Thumbs.db
