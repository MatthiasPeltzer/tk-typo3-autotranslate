{
    "name": "thieleundklose/autotranslate",
    "type": "typo3-cms-extension",
    "description": "This extension provides automatic translation of pages and content elements via DeepL API.",
    "authors": [
        {
            "name": "Mike Zimmer",
            "email": "typo3@thieleundklose.de",
            "homepage": "https://www.thieleundklose.de",
            "role": "Developer"
        }
    ],
    "version": "3.0.4",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">= 8.2 < 8.6",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-simplexml": "*",
        "typo3/cms-core": "^13.4 || ^14.0",
        "deeplcom/deepl-php": "^1.5"
    },
    "require-dev": {
        "typo3/testing-framework": "^8.0 || ^9.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "ThieleUndKlose\\Autotranslate\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ThieleUndKlose\\Autotranslate\\Tests\\": "Tests"
        }
    },
    "replace": {
        "typo3-ter/autotranslate": "self.version"
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin",
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "TYPO3\\TestingFramework\\Composer\\ExtensionTestEnvironment::prepare"
        ],
        "test:unit": "phpunit -c Build/phpunit/UnitTests.xml",
        "test:functional": "phpunit -c Build/phpunit/FunctionalTests.xml",
        "analyse": "phpstan analyse -c Build/phpstan.neon --memory-limit=1G"
    },
    "extra": {
        "typo3/cms": {
            "cms-package-dir": "{$vendor-dir}/typo3/cms",
            "web-dir": ".Build/public",
            "extension-key": "autotranslate"
        }
    }
}